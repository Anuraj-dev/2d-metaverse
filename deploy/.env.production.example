# Log verbosity for the backend (pino): fatal|error|warn|info|debug|trace.
LOG_LEVEL=info
POSTGRES_DB=metaverse
POSTGRES_USER=metaverse
POSTGRES_PASSWORD=replace-with-a-random-database-password
DATABASE_URL=postgres://metaverse:replace-with-url-encoded-password@postgres:5432/metaverse
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_TTL=7d
CORS_ORIGINS=https://app.example.com
LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_URL=http://livekit:7880
LIVEKIT_API_KEY=replace-with-random-livekit-key
LIVEKIT_API_SECRET=replace-with-at-least-32-random-characters
STAGE_KEY=replace-with-stage-presenter-key
MAP_JSON_URL=/assets/maps/space.json
TURN_DOMAIN=turn.example.com
# Watchdog alerts — create a bot via @BotFather and get your chat id.
# When both are set, the alerter container posts container-failure alerts here.
TELEGRAM_BOT_TOKEN=123456789:replace-with-botfather-token
TELEGRAM_CHAT_ID=-1001234567890
# Group id of /var/run/docker.sock, added to the alerter container so it can
# read the Docker events stream. Leave unset: deploy-remote.sh derives it from
# the socket on the box (stat -c %g /var/run/docker.sock; 109 fallback if the
# socket is unreadable). A non-empty value here skips derivation entirely and
# is used as-is — set it only if the auto-derived gid is wrong for the box.
# DOCKER_GID=109
