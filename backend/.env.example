NODE_ENV=development
PORT=3001
# Log verbosity: fatal|error|warn|info|debug|trace. Use debug in dev, info in prod.
LOG_LEVEL=debug
DATABASE_URL=postgres://metaverse:metaverse@localhost:5432/metaverse
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_TTL=7d
CORS_ORIGINS=http://localhost:5173
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=local-development-livekit-secret-change-me
STAGE_KEY=stage-presenter-123
MAP_JSON_URL=/assets/maps/campus.json
TRUST_PROXY=false
# Watchdog alerts (production only) — see deploy/README.md for BotFather setup.
# Leave empty locally; when unset the alerter idles and no alerts are sent.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
