# Copy to .env.local for local dev.
#
# Mock mode runs the whole frontend standalone with no backend. It is
# DEVELOPMENT-ONLY — production builds ignore VITE_USE_MOCK and never simulate a
# world; they require a real backend URL or fail with a clear message.
VITE_USE_MOCK=1

# Real backend (Socket.IO + LiveKit). Required in production.
# VITE_USE_MOCK=0
# VITE_SERVER_URL=http://localhost:3001

# ---- Production hosting (e.g. Vercel) must set ----
#   VITE_USE_MOCK=0
#   VITE_SERVER_URL=https://api.example.com
