NODE_ENV=development
LOG_LEVEL=debug
POSTGRES_DB=metaverse
POSTGRES_USER=metaverse
POSTGRES_PASSWORD=metaverse
DATABASE_URL=postgres://metaverse:metaverse@postgres:5432/metaverse
REDIS_URL=redis://redis:6379
JWT_SECRET=local-development-jwt-secret-change-me-now
JWT_TTL=7d
CORS_ORIGINS=http://localhost:5173
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_URL=http://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=local-development-livekit-secret-change-me
ROOM_1_KEY=1234
ROOM_2_KEY=4321
ROOM_3_KEY=3333
ROOM_4_KEY=4444
ROOM_5_KEY=5555
ROOM_6_KEY=6666
STAGE_KEY=stage-presenter-123
MAP_JSON_URL=/assets/maps/campus.json
TRUST_PROXY=false
# Production AWS override only (for LiveKit embedded TURN/TLS)
TURN_DOMAIN=turn.example.com
# Watchdog alerts (production only) — see deploy/README.md for BotFather setup
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
